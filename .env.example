# Copy this file to .env and fill in real values.  NEVER commit .env (it's gitignored).

# ── PostgreSQL (read by docker compose) ─────────────────────────────────────
POSTGRES_USER=sitinform_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=sitinform_db

# ── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# ── Anonymity HMAC key — losing this breaks every report's anonymity link ───
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET_KEY=change-me

# ── AES-256 field-encryption key — losing this makes encrypted data unreadable
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me

# ── App connection string (used when Flask runs INSIDE docker, host = 'db') ──
DATABASE_URL=postgresql://sitinform_user:changeme_strong_password@db:5432/sitinform_db
